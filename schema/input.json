{
  "$defs": {
    "extractAxiSourceInput": {
      "additionalProperties": true,
      "properties": {
        "$schema": {
          "const": "https://kleverhq.github.io/wavepeek/schema-input-v2.2.json",
          "description": "Input schema URL for this source document.",
          "type": "string"
        },
        "includes": {
          "description": "Regexes selecting waveform signal candidates for AXI auto-mapping.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "kind": {
          "const": "extract.axi.source",
          "description": "Input document kind discriminator.",
          "type": "string"
        },
        "maps": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Explicit mappings from lowercase AXI standard signal names to waveform signal names.",
          "type": "object"
        },
        "name": {
          "description": "AXI port name metadata. Defaults to axi.",
          "type": [
            "string",
            "null"
          ]
        },
        "profile": {
          "description": "AXI profile: axi3, axi4, or axi4-lite. Defaults to axi4.",
          "enum": [
            "axi3",
            "axi4",
            "axi4-lite"
          ],
          "type": "string"
        }
      },
      "required": [
        "$schema",
        "kind"
      ],
      "type": "object"
    },
    "extractGenericSource": {
      "additionalProperties": true,
      "properties": {
        "name": {
          "description": "Source name emitted in extract rows.",
          "type": "string"
        },
        "on": {
          "description": "Edge-only event expression that selects row candidate times.",
          "type": "string"
        },
        "payload": {
          "description": "Ordered payload signal names for this source.",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "when": {
          "description": "Boolean expression evaluated at the pre-edge sample time.",
          "type": "string"
        }
      },
      "required": [
        "name",
        "on",
        "when",
        "payload"
      ],
      "type": "object"
    },
    "extractGenericSourcesInput": {
      "additionalProperties": true,
      "properties": {
        "$schema": {
          "const": "https://kleverhq.github.io/wavepeek/schema-input-v2.2.json",
          "description": "Input schema URL for this source document.",
          "type": "string"
        },
        "kind": {
          "const": "extract.generic.sources",
          "description": "Input document kind discriminator.",
          "type": "string"
        },
        "sources": {
          "description": "Ordered extraction sources.",
          "items": {
            "$ref": "#/$defs/extractGenericSource"
          },
          "minItems": 1,
          "type": "array"
        }
      },
      "required": [
        "$schema",
        "kind",
        "sources"
      ],
      "type": "object"
    }
  },
  "$id": "https://kleverhq.github.io/wavepeek/schema-input-v2.2.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Canonical schema for wavepeek JSON input documents.",
  "oneOf": [
    {
      "$ref": "#/$defs/extractGenericSourcesInput"
    },
    {
      "$ref": "#/$defs/extractAxiSourceInput"
    }
  ],
  "title": "wavepeek JSON input documents"
}
