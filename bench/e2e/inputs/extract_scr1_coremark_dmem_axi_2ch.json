{
  "$schema": "https://kleverhq.github.io/wavepeek/schema-input-v2.1.json",
  "kind": "extract.generic.sources",
  "sources": [
    {
      "name": "axi_dmem_aw",
      "on": "posedge clk iff axi_rst_n",
      "when": "io_axi_dmem_awvalid && io_axi_dmem_awready",
      "payload": [
        "io_axi_dmem_awaddr",
        "io_axi_dmem_awlen",
        "io_axi_dmem_awsize",
        "io_axi_dmem_awburst"
      ]
    },
    {
      "name": "axi_dmem_ar",
      "on": "posedge clk iff axi_rst_n",
      "when": "io_axi_dmem_arvalid && io_axi_dmem_arready",
      "payload": [
        "io_axi_dmem_araddr",
        "io_axi_dmem_arlen",
        "io_axi_dmem_arsize",
        "io_axi_dmem_arburst"
      ]
    }
  ]
}
